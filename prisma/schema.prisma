generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  district_admin
  school_admin
  tech_admin
  interventionist
  instructional_coach
  data_analyst
  support_admin
  teacher
  student
  parent
}

enum CreditRecoveryProgramType {
  course_recovery
  eoc_remediation
  bridge_readiness
}

enum CreditRecoveryEnrollmentStatus {
  assigned
  in_progress
  ready_for_review
  completed
  archived
}

enum CreditRecoveryReason {
  credit_recovery
  grade_forgiveness
  eoc_remediation
  bridge_readiness
}

enum CreditRecoveryProgressStatus {
  not_started
  in_progress
  mastered
  needs_review
}

model User {
  id           String               @id @default(cuid())
  fullName     String
  email        String               @unique
  passwordHash String
  role         UserRole             @default(student)
  districtId   String               @default("default-district")
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  resetTokens  PasswordResetToken[]
  grantedDelegations DelegationGrant[] @relation("DelegationGrantor")
  receivedDelegations DelegationGrant[] @relation("DelegationGrantee")
  policyUpdates DistrictRolePermissionOverride[] @relation("PolicyUpdatedBy")
  policySnapshots DistrictPolicySnapshot[] @relation("PolicySnapshotCreatedBy")
  trialRunSnapshots TrialRunSnapshot[]
  assignedCreditRecoveryEnrollments CreditRecoveryEnrollment[] @relation("CreditRecoveryAssignedBy")
  studentCreditRecoveryEnrollments  CreditRecoveryEnrollment[] @relation("CreditRecoveryStudent")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model DelegationGrant {
  id            String    @id @default(cuid())
  grantorUserId String
  granteeUserId String
  targetRole    UserRole
  reason        String?
  startsAt      DateTime
  endsAt        DateTime
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())
  grantor       User      @relation("DelegationGrantor", fields: [grantorUserId], references: [id], onDelete: Cascade)
  grantee       User      @relation("DelegationGrantee", fields: [granteeUserId], references: [id], onDelete: Cascade)

  @@index([grantorUserId])
  @@index([granteeUserId])
  @@index([targetRole])
  @@index([startsAt, endsAt])
}

model DistrictRolePermissionOverride {
  id              String   @id @default(cuid())
  districtId      String
  role            UserRole
  permission      String
  enabled         Boolean
  updatedByUserId String?
  updatedAt       DateTime @updatedAt
  updatedBy       User?    @relation("PolicyUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([districtId, role, permission])
  @@index([districtId, role])
}

model DistrictPolicySnapshot {
  id              String   @id @default(cuid())
  districtId      String
  label           String
  preset          String?
  reason          String?
  entries         Json
  createdByUserId String?
  createdAt       DateTime @default(now())
  createdBy       User?    @relation("PolicySnapshotCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([districtId, createdAt])
}

model TrialRunSnapshot {
  id          String   @id @default(cuid())
  districtId  String
  userId      String
  name        String
  fileName    String?
  rowCount    Int
  invalidRows Int      @default(0)
  avgPre      Float
  avgPost     Float
  avgGain     Float
  improvedCount Int
  rows        Json
  createdAt   DateTime @default(now())
  deletedAt   DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([districtId, createdAt])
  @@index([userId, createdAt])
  @@index([districtId, deletedAt, createdAt])
}

model CreditRecoveryProgram {
  id                String                     @id @default(cuid())
  districtId        String                     @default("catalog")
  slug              String
  title             String
  description       String
  subjectArea       String                     @default("mathematics")
  floridaCourseCode String?
  recoveryType      CreditRecoveryProgramType
  eocCourse         String?
  gradeBandStart    Int
  gradeBandEnd      Int
  standardsFramework String                    @default("Florida B.E.S.T.")
  transcriptEligible Boolean                   @default(false)
  masteryModel      String                     @default("standards_mastery")
  supportModel      Json
  policyConfig      Json
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  modules           CreditRecoveryModule[]
  enrollments       CreditRecoveryEnrollment[]

  @@unique([districtId, slug])
  @@index([districtId, subjectArea, recoveryType])
}

model CreditRecoveryModule {
  id                 String                            @id @default(cuid())
  programId          String
  slug               String
  title              String
  description        String
  sequence           Int
  benchmarkCode      String
  reportingCategory  String
  prerequisiteSkills Json
  masteryThreshold   Int                               @default(80)
  estimatedMinutes   Int
  supports           Json
  createdAt          DateTime                          @default(now())
  updatedAt          DateTime                          @updatedAt
  program            CreditRecoveryProgram             @relation(fields: [programId], references: [id], onDelete: Cascade)
  progressRecords    CreditRecoveryEnrollmentProgress[]

  @@unique([programId, slug])
  @@unique([programId, sequence])
  @@index([benchmarkCode])
}

model CreditRecoveryEnrollment {
  id                          String                          @id @default(cuid())
  districtId                  String
  studentUserId               String
  assignedByUserId            String
  programId                   String
  status                      CreditRecoveryEnrollmentStatus  @default(assigned)
  reason                      CreditRecoveryReason
  originalCourseCode          String?
  originalCourseName          String?
  targetCompletionAt          DateTime?
  startedAt                   DateTime?
  completedAt                 DateTime?
  lastActivityAt              DateTime?
  masteryPercent              Float                           @default(0)
  transcriptReplacementEligible Boolean                       @default(false)
  eocRequired                 Boolean                         @default(false)
  transcriptFlags             Json?
  notes                       String?
  createdAt                   DateTime                        @default(now())
  updatedAt                   DateTime                        @updatedAt
  student                     User                            @relation("CreditRecoveryStudent", fields: [studentUserId], references: [id], onDelete: Cascade)
  assignedBy                  User                            @relation("CreditRecoveryAssignedBy", fields: [assignedByUserId], references: [id], onDelete: Cascade)
  program                     CreditRecoveryProgram           @relation(fields: [programId], references: [id], onDelete: Cascade)
  moduleProgress              CreditRecoveryEnrollmentProgress[]

  @@index([districtId, studentUserId, status])
  @@index([assignedByUserId, createdAt])
  @@index([programId, status])
}

model CreditRecoveryEnrollmentProgress {
  id             String                       @id @default(cuid())
  enrollmentId   String
  moduleId       String
  status         CreditRecoveryProgressStatus @default(not_started)
  diagnosticScore Float?
  masteryScore   Float?
  benchmarkReady Boolean                      @default(false)
  masteredAt     DateTime?
  lastWorkedAt   DateTime?
  evidence       Json?
  teacherNotes   String?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  enrollment     CreditRecoveryEnrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  module         CreditRecoveryModule         @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, moduleId])
  @@index([status, benchmarkReady])
}
